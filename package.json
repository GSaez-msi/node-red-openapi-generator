{
    "name": "@ggggggggggggggggggggs/node-red-openapi-generator",
    "version": "0.2.2",
    "description": "Simple nodes for straightforward swagger documentation, straight from your Node-Red! Based off of @5minds/node-red-openapi-generator, with several adjustments for your Swagger generating necessities.",
    "license": "Apache",
    "repository": {
        "type": "git",
        "url": "https://github.com/GSaez-msi/node-red-openapi-generator"
    },
    "authors": [
        {
            "name": "G Saez",
            "email": "gsaez@msigrupo.com"
        }
    ],
    "scripts": {
        "lint": "prettier --write --config ./.prettierrc.json \"**/*.{html,js}\""
    },
    "keywords": [
        "node-red",
        "swagger",
        "open-api"
    ],
    "node-red": {
        "version": ">=4.1.x",
        "nodes": {
            "swagger": "swagger/swagger.js",
            "swaggertemplate": "swagger/swaggertemplate.js"
        }
    },
    "conflicts": {
        "node-red-node-swagger": "<0.3.0"
    },
    "dependencies": {
        "swagger-ui-dist": "^5.29.0"
    },
    "engines": {
        "node": ">=18.0.0"
      }
}
